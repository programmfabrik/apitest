[
    // number_gt
    {
        "name": "check control number_gt (10 > 9)",
        "request": {
            "server_url": "http://localhost:9999",
            "endpoint": "bounce-json",
            "method": "POST",
            "body": {
                "num": 10
            }
        },
        "response": {
            "statuscode": 200,
            "body": {
                "body": {
                    "num:control": {
                        "number_gt": 9
                    }
                }
            }
        }
    },
    {
        "name": "check control number_gt (equal value, should fail)",
        "request": {
            "server_url": "http://localhost:9999",
            "endpoint": "bounce-json",
            "method": "POST",
            "body": {
                "num": 10
            }
        },
        "response": {
            "statuscode": 200,
            "body": {
                "body": {
                    "num:control": {
                        "number_gt": 10
                    }
                }
            }
        },
        "reverse_test_result": true
    },
    {
        // string comparison would fail here: "8574" < "999" lexicographically
        "name": "check control number_gt across digit counts (8574 > 999)",
        "request": {
            "server_url": "http://localhost:9999",
            "endpoint": "bounce-json",
            "method": "POST",
            "body": {
                "num": 8574
            }
        },
        "response": {
            "statuscode": 200,
            "body": {
                "body": {
                    "num:control": {
                        "number_gt": 999
                    }
                }
            }
        }
    },

